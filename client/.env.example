# 앱 런타임: Supabase 트랜잭션 풀러(Supavisor, 포트 6543). Cloud Run 다인스턴스 대비.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
# 마이그레이션/seed 전용: direct(session) 연결(포트 5432). 로컬 dev는 미설정 시 DATABASE_URL로 폴백.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

AUTH_SECRET="REPLACE_WITH_A_NEW_SECRET"
AUTH_URL="http://localhost:3000"
NEXT_DEV_ALLOWED_ORIGINS="dev.takeaseat.co.kr"
DEV_HOSTNAME="dev.takeaseat.co.kr"
HTTPS_KEY_PATH="/absolute/path/to/dev.takeaseat.co.kr-key.pem"
HTTPS_CERT_PATH="/absolute/path/to/dev.takeaseat.co.kr.pem"
HTTPS_CA_PATH=""

AUTH_GOOGLE_ID="REPLACE_GOOGLE_ID"
AUTH_GOOGLE_SECRET="REPLACE_GOOGLE_SECRET"

AUTH_KAKAO_ID="REPLACE_KAKAO_ID"
AUTH_KAKAO_SECRET="REPLACE_KAKAO_SECRET"

AUTH_NAVER_ID="REPLACE_NAVER_ID"
AUTH_NAVER_SECRET="REPLACE_NAVER_SECRET"

SEED_OWNER_EMAIL="owner@example.com"
SEED_OWNER_NAME="Salon Owner"

# Slack 알림(Incoming Webhook). 채널 2분기 × 환경(prod/dev) 분리.
# 환경 선택: NODE_ENV=production(클라우드)이면 운영 변수, 그 외(로컬 next dev)면 _DEV 변수.
#           개발에서 운영 변수로 폴백하지 않음 — 미설정 시 해당 알림 no-op.
#
# [biz] 예약·문의 등 매장 비즈니스 알림.
SLACK_WEBHOOK_URL=""        # biz 운영 채널
SLACK_WEBHOOK_URL_DEV=""    # biz 로컬/개발 채널
SLACK_STORE_ID=""           # 설정 시 해당 매장 biz 알림만 전송(미설정 시 전 매장, 매장명 prefix)
#
# [ops] 서버 에러·동기화 실패 등 운영/시스템 알림(매장 무관 전역).
SLACK_WEBHOOK_URL_OPS=""        # ops 운영 채널
SLACK_WEBHOOK_URL_OPS_DEV=""    # ops 로컬/개발 채널(운영과 같은 채널 써도 무방)

# Google AdSense
# 퍼블리셔 ID는 client/lib/ads.ts에 기본값(ca-pub-5655041057903258)이 있어 미설정이어도 동작.
# 다른 계정으로 바꿀 때만 아래로 오버라이드. 개별 광고 유닛(<ins>)은 슬롯 ID가 있어야 렌더됨.
NEXT_PUBLIC_ADSENSE_CLIENT=""
NEXT_PUBLIC_ADSENSE_FOOTER_SLOT=""
NEXT_PUBLIC_ADSENSE_AUTH_SLOT=""
